# Local app/runtime configuration
# Copy this file to .env.local and fill in your project values.
#
# Source of truth recommendation:
# - Keep local/dev secrets in .env.local (or another local secret store you control)
# - Push those same values to Vercel
# - Do not treat Vercel as the only source of truth for encrypted/sensitive secrets,
#   because some of them cannot be read back in plaintext later
#
# Public/readable values:
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
#
# Private/server-only values required for local API testing:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
MISSION_CONTROL_AUTOMATION_TOKEN=replace-with-a-long-random-shared-secret
# Discord delivery for the #daily-brief channel. Preferred: incoming webhook.
# Fallback: bot token + channel ID when a webhook is not available.
DISCORD_DAILY_BRIEF_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_DAILY_BRIEF_CHANNEL_ID=your-discord-channel-id
DISCORD_BOT_TOKEN=your-discord-bot-token
# Optional when running the standalone Mission Control dispatcher runner locally:
# if omitted, runner scripts that use service-role Supabase access will fail fast.
# SUPABASE_SERVICE_ROLE_KEY is intentionally duplicated here as a reminder that
# the standalone runtime/dispatcher path depends on it even if the UI builds.
